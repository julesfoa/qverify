# Copy to .env.local: cp .env.example .env.local

# AI Gateway API key (preferred — get from Vercel dashboard)
# https://vercel.com/{team}/{project}/settings → AI Gateway
# Alternative: run `vercel env pull .env.local` after `vercel login` to use OIDC (no key needed)
AI_GATEWAY_API_KEY=

# Demo mode — if AI_GATEWAY_API_KEY is blank, app streams mock bio automatically
# Set ?mock=true in the URL to force mock mode regardless

# Solana network (devnet for hackathon, no real SOL needed)
NEXT_PUBLIC_SOLANA_NETWORK=devnet
